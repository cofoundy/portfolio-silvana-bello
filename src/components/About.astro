---
import { siteConfig } from "../config";
---

<section
  id="about"
  class="py-20 md:py-32"
  style={`background-color: ${siteConfig.colors.surface}`}
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- 3-column layout: Title | Bio | Pull Quote -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      <!-- Title Column -->
      <div class="lg:col-span-3 reveal-left">
        <p
          class="text-[10px] font-medium uppercase tracking-[0.4em] mb-3"
          style={`color: ${siteConfig.colors.primary}`}
        >
          Sobre mí
        </p>
        <h2
          class="text-4xl md:text-5xl lg:text-6xl font-light"
          style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
        >
          La<br/>Artista
        </h2>
        <div
          class="w-12 h-px mt-6"
          style={`background-color: ${siteConfig.colors.accent}`}
        ></div>
      </div>

      <!-- Content Column -->
      <div class="lg:col-span-5 reveal stagger-1">
        <p class="text-base md:text-lg text-gray-600 leading-[1.9]" style="font-family: 'Montserrat', sans-serif;">
          <Fragment set:html={siteConfig.aboutMe} />
        </p>
      </div>

      <!-- Quote Column -->
      {siteConfig.quote && (
        <div class="lg:col-span-4 reveal-scale stagger-2 flex items-center">
          <blockquote
            class="quote-float relative pl-8 py-4"
            style={`border-left: 2px solid ${siteConfig.colors.accent}`}
          >
            <!-- Large decorative opening quote -->
            <span
              class="absolute -top-4 -left-2 text-8xl font-light leading-none opacity-10"
              style={`color: ${siteConfig.colors.accent}; font-family: 'Cormorant', serif;`}
            >&ldquo;</span>
            <p
              class="text-2xl md:text-3xl font-light italic leading-snug relative"
              style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
            >
              {siteConfig.quote.text}
            </p>
            <footer
              class="mt-6 text-[10px] uppercase tracking-[0.3em]"
              style={`color: ${siteConfig.colors.primary}80`}
            >
              — {siteConfig.quote.author}
            </footer>
          </blockquote>
        </div>
      )}
    </div>

    <!-- Skills -->
    <div class="mt-16 pt-10 border-t reveal stagger-3" style={`border-color: ${siteConfig.colors.primary}10`}>
      <h3
        class="text-[10px] font-medium uppercase tracking-[0.4em] mb-6"
        style={`color: ${siteConfig.colors.primary}80`}
      >
        Especialidades
      </h3>
      <div class="flex flex-wrap gap-3">
        {siteConfig.skills.map((skill, index) => (
          <span
            class={`skill-hover px-6 py-2.5 text-sm font-light cursor-default stagger-${Math.min(index % 6 + 1, 6)}`}
            style={`background-color: white; color: ${siteConfig.colors.primaryDark}; border: 1px solid ${siteConfig.colors.primary}15; font-family: 'Montserrat', sans-serif;`}
          >
            {skill}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
