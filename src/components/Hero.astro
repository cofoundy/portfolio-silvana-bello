---
import { siteConfig } from "../config";
---

<!-- Top Bar with Shimmer -->
<div class="w-full h-1 bar-shimmer"></div>

<section
  id="hero"
  class="relative py-20 md:py-28 lg:py-32"
  style={`background-color: ${siteConfig.colors.surfaceLight}`}
>
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Main Hero Content: 2-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-16 items-center">
      <!-- Photo Column -->
      <div class="md:col-span-5 flex justify-center md:justify-start order-2 md:order-1">
        <div class="relative hero-photo">
          <img
            src="/profile.jpg"
            alt={siteConfig.name}
            class="relative w-64 h-80 md:w-72 md:h-96 lg:w-80 lg:h-[28rem] object-cover shadow-2xl"
            style={`border: 1px solid ${siteConfig.colors.primary}20`}
          />
          <!-- Editorial caption under photo -->
          <p
            class="mt-3 text-xs uppercase tracking-[0.2em] text-center"
            style={`color: ${siteConfig.colors.primary}; font-family: 'Montserrat', sans-serif;`}
          >
            Lima, Peru
          </p>
        </div>
      </div>

      <!-- Text Content Column -->
      <div class="md:col-span-7 order-1 md:order-2 text-center md:text-left">
        <!-- Editorial overline -->
        <p
          class="hero-subtitle text-xs md:text-sm font-medium uppercase tracking-[0.4em] mb-6"
          style={`color: ${siteConfig.colors.primary}; font-family: 'Montserrat', sans-serif;`}
        >
          Fotógrafa &middot; Directora Creativa
        </p>

        <h1
          class="hero-title text-5xl md:text-6xl lg:text-8xl font-light tracking-wide leading-[0.9]"
          style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
        >
          Silvana<br/>Bello
        </h1>

        <!-- Thin separator -->
        <div
          class="w-20 h-px my-6 mx-auto md:mx-0"
          style={`background-color: ${siteConfig.colors.accent}`}
        ></div>

        <!-- Tagline in italic serif -->
        {siteConfig.tagline && (
          <p
            class="hero-description text-xl md:text-2xl lg:text-3xl leading-relaxed mb-10 max-w-lg mx-auto md:mx-0 italic"
            style={`color: ${siteConfig.colors.primary}80; font-family: 'Cormorant', serif;`}
          >
            {siteConfig.tagline}
          </p>
        )}

        <!-- CTA Buttons — editorial style -->
        <div class="hero-cta flex flex-col sm:flex-row gap-4 justify-center md:justify-start mb-8">
          <a
            href="#portfolio"
            class="btn-hover inline-flex items-center justify-center gap-2 px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] transition-all duration-300"
            style={`background-color: ${siteConfig.colors.primaryDark}; color: ${siteConfig.colors.surfaceLight};`}
          >
            Ver mi trabajo
          </a>
          <a
            href={`mailto:${siteConfig.social?.email}?subject=${siteConfig.cta?.emailSubject || 'Contacto'}`}
            class="btn-hover inline-flex items-center justify-center gap-2 px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] transition-all duration-300"
            style={`border: 1px solid ${siteConfig.colors.primaryDark}; color: ${siteConfig.colors.primaryDark}; background: transparent;`}
          >
            Conversemos
          </a>
        </div>

        <!-- Social Links — minimal -->
        <div class="hero-social flex gap-4 justify-center md:justify-start">
          {siteConfig.social?.linkedin && (
            <a
              href={siteConfig.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="icon-hover w-10 h-10 rounded-full flex items-center justify-center border transition-all duration-300"
              style={`border-color: ${siteConfig.colors.primary}40; color: ${siteConfig.colors.primaryDark}`}
              aria-label="LinkedIn"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.instagram && (
            <a
              href={siteConfig.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="icon-hover w-10 h-10 rounded-full flex items-center justify-center border transition-all duration-300"
              style={`border-color: ${siteConfig.colors.primary}40; color: ${siteConfig.colors.primaryDark}`}
              aria-label="Instagram"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.email && (
            <a
              href={`mailto:${siteConfig.social.email}`}
              class="icon-hover w-10 h-10 rounded-full flex items-center justify-center border transition-all duration-300"
              style={`border-color: ${siteConfig.colors.primary}40; color: ${siteConfig.colors.primaryDark}`}
              aria-label="Email"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Stats / Trust Bar -->
    {siteConfig.stats && siteConfig.stats.length > 0 && (
      <div
        class="hero-stats mt-20 py-8 grid grid-cols-3 gap-4 md:gap-8 border-y"
        style={`border-color: ${siteConfig.colors.primary}20`}
      >
        {siteConfig.stats.map((stat, index) => (
          <div class={`text-center stat-number ${index === 1 ? 'border-x' : ''}`} style={index === 1 ? `border-color: ${siteConfig.colors.primary}20` : ''}>
            <div
              class="text-3xl md:text-4xl font-light"
              style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
            >{stat.value}</div>
            <div
              class="text-[10px] md:text-xs uppercase tracking-[0.2em] mt-1"
              style={`color: ${siteConfig.colors.primary}`}
            >{stat.label}</div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<!-- Bottom Bar with Shimmer -->
<div class="w-full h-1 bar-shimmer"></div>
