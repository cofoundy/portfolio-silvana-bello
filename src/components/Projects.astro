---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{hasProjects && (
  <section
    id="portfolio"
    class="py-16 md:py-24"
    style={`background-color: ${siteConfig.colors.surface}`}
  >
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <!-- Editorial header -->
      <div class="text-center mb-16 reveal">
        <p
          class="text-xs font-medium uppercase tracking-[0.3em] mb-3"
          style={`color: ${siteConfig.colors.primary}`}
        >
          Portfolio
        </p>
        <h2
          class="text-4xl md:text-5xl font-light"
          style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
        >
          Mi Trabajo
        </h2>
        <div
          class="w-12 h-px mx-auto mt-4"
          style={`background-color: ${siteConfig.colors.accent}`}
        ></div>
      </div>

      <!-- 2-column gallery grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {siteConfig.projects.map((project, index) => (
          <div
            class={`reveal stagger-${index + 1} project-card card-hover p-8 group`}
            style={`background-color: white; border: 1px solid ${siteConfig.colors.primary}15`}
          >
            <!-- Project number — editorial detail -->
            <span
              class="text-xs uppercase tracking-[0.3em] mb-4 block"
              style={`color: ${siteConfig.colors.primary}60`}
            >
              {String(index + 1).padStart(2, '0')}
            </span>

            <h3
              class="text-2xl md:text-3xl font-light mb-3 transition-colors duration-300"
              style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
            >
              {project.link ? (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="link-underline hover:opacity-70 transition-opacity"
                >
                  {project.name}
                </a>
              ) : (
                project.name
              )}
            </h3>

            <p class="text-sm text-gray-500 mb-6 leading-relaxed" style="font-family: 'Montserrat', sans-serif;">
              <Fragment set:html={project.description} />
            </p>

            <div class="flex flex-wrap gap-2">
              {project.skills.map((skill) => (
                <span
                  class="text-xs px-3 py-1.5 font-light uppercase tracking-wider"
                  style={`background-color: ${siteConfig.colors.surface}; color: ${siteConfig.colors.primary}; border: 1px solid ${siteConfig.colors.primary}20`}
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
