---
import { siteConfig } from "../config";

const hasServices = siteConfig.services && siteConfig.services.length > 0;

const iconPaths: Record<string, string> = {
  code: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  mobile: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
  cloud: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z",
  building: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  user: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
  academic: "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
  chart: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  shield: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  heart: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  chat: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
  star: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
};

const serviceNumbers = ["I", "II", "III"];
---

{hasServices && (
  <div class="w-full h-px" style={`background-color: ${siteConfig.colors.primary}10`}></div>

  <section
    id="services"
    class="py-20 md:py-32"
    style="background-color: white"
  >
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Header — editorial style -->
      <div class="text-center mb-20 reveal">
        <p
          class="text-[10px] font-medium uppercase tracking-[0.4em] mb-4"
          style={`color: ${siteConfig.colors.primary}`}
        >
          Servicios
        </p>
        <h2
          class="text-5xl md:text-6xl font-light mb-4"
          style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
        >
          Lo Que Hago
        </h2>
        <div
          class="w-16 h-px mx-auto"
          style={`background-color: ${siteConfig.colors.accent}`}
        ></div>
      </div>

      <!-- Service Cards — larger with roman numerals -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        {siteConfig.services.map((service, index) => (
          <div
            class={`reveal stagger-${index + 1} group card-hover p-10 text-center relative`}
            style={`background-color: ${siteConfig.colors.surfaceLight}; border: 1px solid ${siteConfig.colors.primary}08`}
          >
            <!-- Roman numeral watermark -->
            <span
              class="absolute top-4 right-6 text-6xl font-light opacity-[0.04]"
              style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
            >
              {serviceNumbers[index]}
            </span>

            <div
              class="w-16 h-16 mx-auto mb-8 flex items-center justify-center transition-all duration-300 group-hover:scale-110"
              style={`border: 1px solid ${siteConfig.colors.accent}30`}
            >
              <svg
                class="w-7 h-7"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                style={`color: ${siteConfig.colors.accent}`}
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d={iconPaths[service.icon] || iconPaths.star}></path>
              </svg>
            </div>

            <h3
              class="text-2xl md:text-3xl font-light mb-4"
              style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant', serif;`}
            >
              {service.title}
            </h3>

            <p class="text-gray-500 text-sm mb-8 leading-relaxed" style="font-family: 'Montserrat', sans-serif;">
              <Fragment set:html={service.description} />
            </p>

            <ul class="space-y-3 text-left">
              {service.items.map((item) => (
                <li class="flex items-center gap-3 text-sm text-gray-600">
                  <span
                    class="w-1.5 h-px flex-shrink-0"
                    style={`background-color: ${siteConfig.colors.accent}`}
                  ></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
